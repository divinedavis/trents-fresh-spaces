# Trent's Fresh Spaces — booking API config. Copy to .env and fill in.
# The site + booking work without these, but calendar sync/email need them.

PORT=3007
TZ=America/New_York

# Protect the admin endpoints (GET /api/admin/bookings). Set to a long random string.
ADMIN_TOKEN=

# --- One-time setup link (Trent connects email/calendars at /setup.html) ---
# Single-use, short-lived gate for POST /api/setup. Issue a fresh long random
# value (e.g. `openssl rand -hex 24`) and set SETUP_TOKEN_ISSUED_AT to the
# current Unix epoch in MILLISECONDS. The token is required as the X-Setup-Token
# header (never in the URL), expires after SETUP_TOKEN_TTL_MIN minutes, and is
# auto-removed from .env after the first successful connect. To let Trent run
# setup again, add a new SETUP_TOKEN + fresh SETUP_TOKEN_ISSUED_AT and restart.
# The setup link to send Trent is then: https://trentsfreshspaces.com/setup.html#t=<SETUP_TOKEN>
# SETUP_TOKEN=
# SETUP_TOKEN_ISSUED_AT=
# SETUP_TOKEN_TTL_MIN=60

# --- Booking rules (optional overrides) ---
# LEAD_TIME_HOURS=12
# MAX_DAYS_AHEAD=45
# SLOT_STEP_MIN=30
# BUFFER_MIN=15
# DUR_ESTIMATE_MIN=60
# DUR_CONSULT_MIN=20

# --- Trent's email(s): receive the calendar invite + new-booking alerts ---
# Comma-separated; first is the calendar organizer/attendee.
OWNER_EMAIL=trent.freeland@gmail.com
OWNER_NAME=Trent Freeland

# --- Read Trent's calendars (so his manual blocks hide site slots) ---
# Comma-separated read-only ICS feed URLs:
#   Google Calendar -> Settings > [calendar] > "Secret address in iCal format"
#   iCloud Calendar -> share a calendar as "Public Calendar", copy the webcal/https URL
ICS_FEEDS=
# BUSY_CACHE_TTL_SEC=300

# --- Email (sends ICS invites + confirmations). Gmail: use an App Password ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# --- OPTIONAL: iCloud CalDAV write-back (instant insert into Apple Calendar) ---
# ICLOUD_USERNAME=               # Apple ID email
# ICLOUD_APP_PASSWORD=           # appleid.apple.com > Sign-In & Security > App-Specific Passwords
# ICLOUD_CALENDAR_URL=           # the specific calendar collection URL on caldav.icloud.com
